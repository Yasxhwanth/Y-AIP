# Y-AIP — Environment Variables
# Copy this to .env and fill in secrets before starting
# Never commit .env to git

# ─────────────────────────────────────────
# POSTGRES
# ─────────────────────────────────────────
POSTGRES_USER=yaip
POSTGRES_PASSWORD=yaip_dev_secret
POSTGRES_DB=yaip

# ─────────────────────────────────────────
# NEO4J
# ─────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=yaip_dev_secret
NEO4J_URI=bolt://localhost:7687

# ─────────────────────────────────────────
# CLICKHOUSE
# ─────────────────────────────────────────
CLICKHOUSE_USER=yaip
CLICKHOUSE_PASSWORD=yaip_dev_secret
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=audit

# ─────────────────────────────────────────
# KAFKA
# ─────────────────────────────────────────
KAFKA_BROKERS=localhost:29092
SCHEMA_REGISTRY_URL=http://localhost:8081

# ─────────────────────────────────────────
# MINIO (S3-compatible)
# ─────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=yaip_minio
MINIO_SECRET_KEY=yaip_minio_secret
MINIO_BUCKET_DATA=yaip-data
MINIO_BUCKET_LOGS=yaip-logs
MINIO_BUCKET_MODELS=yaip-models

# ─────────────────────────────────────────
# TEMPORAL
# ─────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=yaip-prod
TEMPORAL_TASK_QUEUE=actions

# ─────────────────────────────────────────
# OPA
# ─────────────────────────────────────────
OPA_URL=http://localhost:8181
OPA_POLICY_PATH=/v1/data/yaip/authz/allow

# ─────────────────────────────────────────
# KEYCLOAK
# ─────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=yaip
KEYCLOAK_CLIENT_ID=yaip-backend
KEYCLOAK_CLIENT_SECRET=change_me_in_prod
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ─────────────────────────────────────────
# OPENBAO (secrets — replaces HashiCorp Vault)
# ─────────────────────────────────────────
OPENBAO_ADDR=http://localhost:8200
OPENBAO_ROOT_TOKEN=yaip-dev-root-token

# ─────────────────────────────────────────
# LLM ROUTING
# ─────────────────────────────────────────
LITELLM_MODE=local                          # local | cloud | consensus
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama4:scout
# ANTHROPIC_API_KEY=sk-ant-...             # Uncomment for cloud mode
# OPENAI_API_KEY=sk-...                    # Uncomment for cloud mode

# ─────────────────────────────────────────
# MCP GATEWAY
# ─────────────────────────────────────────
MCP_GATEWAY_PORT=4000
MCP_GATEWAY_SECRET=change_me_in_prod

# ─────────────────────────────────────────
# AGENT ENGINE (FastAPI)
# ─────────────────────────────────────────
AGENT_ENGINE_PORT=8000
LANGSMITH_API_KEY=                          # Optional: leave blank to disable tracing
LANGSMITH_PROJECT=yaip-dev

# ─────────────────────────────────────────
# DEPLOYMENT MODE
# ─────────────────────────────────────────
DEPLOYMENT_MODE=local                       # local | cloud | on_prem | air_gap
CLASSIFICATION_MODE=UNCLASSIFIED
PRESIDIO_ENABLED=true
TEE_ENABLED=false
