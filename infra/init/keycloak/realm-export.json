    "clients": [
        {
            "clientId": "yaip-backend",
            "enabled": true,
            "clientAuthenticatorType": "client-secret",
            "secret": "change_me_in_prod",
            "standardFlowEnabled": true,
            "directAccessGrantsEnabled": true,
            "serviceAccountsEnabled": true,
            "protocolMappers": [
                {
                    "name": "clearance-mapper",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-usermodel-attribute-mapper",
                    "config": {
                        "user.attribute": "clearance",
                        "claim.name": "clearance",
                        "jsonType.label": "String",
                        "id.token.claim": "true",
                        "access.token.claim": "true"
                    }
                },
                {
                    "name": "us-person-mapper",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-usermodel-attribute-mapper",
                    "config": {
                        "user.attribute": "us_person",
                        "claim.name": "us_person",
                        "jsonType.label": "boolean",
                        "id.token.claim": "true",
                        "access.token.claim": "true"
                    }
                },
                {
                    "name": "permitted-connectors-mapper",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-usermodel-attribute-mapper",
                    "config": {
                        "user.attribute": "permitted_connectors",
                        "claim.name": "permitted_connectors",
                        "jsonType.label": "JSON",
                        "multivalued": "true",
                        "id.token.claim": "true",
                        "access.token.claim": "true"
                    }
                },
                {
                    "name": "purposes-mapper",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-usermodel-attribute-mapper",
                    "config": {
                        "user.attribute": "purpose_ids",
                        "claim.name": "purpose_ids",
                        "jsonType.label": "JSON",
                        "multivalued": "true",
                        "id.token.claim": "true",
                        "access.token.claim": "true"
                    }
                }
            ]
        },
        {
            "clientId": "yaip-agent",
            "enabled": true,
            "clientAuthenticatorType": "client-secret",
            "secret": "agent-secret-change-in-prod",
            "serviceAccountsEnabled": true,
            "defaultRoles": [
                "AGENT"
            ],
            "attributes": {
                "clearance": "SECRET",
                "us_person": "true",
                "permitted_connectors": "connector-postgres,connector-kafka",
                "purpose_ids": "mission_planning"
            }
